# ── OpenDray environment ──────────────────────────────────────────────
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
# All fields have defaults in code unless marked REQUIRED.

# ── Server ───────────────────────────────────────────────────────
# HTTP listen address — host:port or :port for wildcard bind.
LISTEN_ADDR=:8640

# ── PostgreSQL ───────────────────────────────────────────────────
# REQUIRED. No default.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=opendray
# REQUIRED. Create a dedicated user with CRUD-only rights:
#   CREATE USER opendray WITH PASSWORD '...';
#   GRANT CONNECT ON DATABASE opendray TO opendray;
#   GRANT USAGE  ON SCHEMA public TO opendray;
#   GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES    IN SCHEMA public TO opendray;
#   GRANT USAGE, SELECT                ON ALL SEQUENCES IN SCHEMA public TO opendray;
DB_PASSWORD=
DB_NAME=opendray

# ── Auth ─────────────────────────────────────────────────────────
# Leave empty in development to disable JWT auth entirely. In
# production set to 32+ random bytes so tokens can't be forged.
# Tokens have a 7-day TTL.
JWT_SECRET=

# Admin credentials for the /api/auth/login endpoint. REQUIRED when
# JWT_SECRET is set — otherwise startup fails fast.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Plugins ──────────────────────────────────────────────────────
# Directory containing plugin manifests (scanned recursively).
PLUGIN_DIR=./plugins

# When true, OpenDray re-attaches any orphaned PTYs it finds at startup
# (useful after an OpenDray crash — user sessions survive if the DB row
# and PID are still intact).
AUTO_RESUME=false

# Seconds of PTY silence before an "idle" event fires. Downstream
# notifier plugins (Telegram, future webhooks) trigger on this.
IDLE_THRESHOLD_SECONDS=8

# ── Telegram bridge (optional) ───────────────────────────────────
# Only read when the `telegram` panel plugin is enabled AND its
# manifest config has not supplied a token. Prefer plugin config
# over env when running multiple OpenDray instances per host.
OPENDRAY_TELEGRAM_BOT_TOKEN=

# ── LLM Provider API keys (optional) ─────────────────────────────
# The `llm-providers` panel stores the env-var NAME, not the value.
# Set the actual key here and the gateway forwards it as Bearer
# token when proxying to the upstream. Local Ollama / LM Studio
# typically don't need a key.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Per-plugin database panel credentials (optional) ─────────────
# The `database` panel plugin reads its password from
# OPENDRAY_DB_PASSWORD_<plugin-instance-name> so the password never
# lands in the plugin's JSON config. Replace <PLUGIN_NAME> with
# the actual plugin row name and add one line per DB instance.
# OPENDRAY_DB_PASSWORD_MY_DB_PANEL=

# ── Deployment (optional, only for make deploy / CI) ─────────────
# SSH target for `make deploy`. Override per-host when needed.
# Example: OPENDRAY_DEPLOY_HOST=root@10.0.0.42
OPENDRAY_DEPLOY_HOST=
