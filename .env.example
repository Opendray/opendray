# ── OpenDray environment ──────────────────────────────────────────────
#
# For most setups you DO NOT need this file. Run the binary once and the
# browser setup wizard writes ~/.opendray/config.toml for you.
#
# Copy this to `.env` only if you prefer env-var configuration (Docker /
# LXC deployments, CI, or custom orchestration). Env vars override the
# config file, so setting DB_HOST here skips the wizard entirely.
#
# `.env` is gitignored.

# ── Server ───────────────────────────────────────────────────────
# HTTP listen address — host:port or :port for wildcard bind.
LISTEN_ADDR=:8640

# ── PostgreSQL ───────────────────────────────────────────────────
# REQUIRED. No default.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=opendray
# REQUIRED. Create a dedicated user with CRUD-only rights:
#   CREATE USER opendray WITH PASSWORD '...';
#   GRANT CONNECT ON DATABASE opendray TO opendray;
#   GRANT USAGE  ON SCHEMA public TO opendray;
#   GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES    IN SCHEMA public TO opendray;
#   GRANT USAGE, SELECT                ON ALL SEQUENCES IN SCHEMA public TO opendray;
DB_PASSWORD=
DB_NAME=opendray

# ── Auth ─────────────────────────────────────────────────────────
# Leave empty in development to disable JWT auth entirely. In
# production set to 32+ random bytes so tokens can't be forged.
# Tokens have a 7-day TTL.
JWT_SECRET=

# Admin credentials for the /api/auth/login endpoint. REQUIRED when
# JWT_SECRET is set — otherwise startup fails fast.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Plugins ──────────────────────────────────────────────────────
# Directory containing plugin manifests (scanned recursively).
PLUGIN_DIR=./plugins

# When true, OpenDray re-attaches any orphaned PTYs it finds at startup
# (useful after an OpenDray crash — user sessions survive if the DB row
# and PID are still intact).
AUTO_RESUME=false

# Seconds of PTY silence before an "idle" event fires. Downstream
# notifier plugins (Telegram, future webhooks) trigger on this.
IDLE_THRESHOLD_SECONDS=8

# ── Telegram bridge (optional) ───────────────────────────────────
# Only read when the `telegram` panel plugin is enabled AND its
# manifest config has not supplied a token. Prefer plugin config
# over env when running multiple OpenDray instances per host.
OPENDRAY_TELEGRAM_BOT_TOKEN=

# ── Agent CLI keys (optional) ────────────────────────────────────
# Each builtin agent plugin declares which env var its CLI reads —
# set the corresponding key here and it's inherited by the spawned
# session. Leave blank to use each CLI's own cached OAuth login.
#
#   claude    → ANTHROPIC_API_KEY   (plugins/builtin/claude/manifest.json)
#   codex     → OPENAI_API_KEY      (plugins/builtin/codex/manifest.json)
#   gemini    → GOOGLE_API_KEY      (plugins/builtin/gemini/manifest.json)
#   qwen-code → OPENAI_API_KEY or DASHSCOPE_API_KEY
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── LLM Provider keys (optional, naming is user-chosen) ──────────
# The `llm-providers` panel stores the env-var NAME per provider
# row. The name is arbitrary: register a Groq provider with
# apiKeyEnv=GROQ_API_KEY, OpenRouter with apiKeyEnv=OPENROUTER_KEY,
# etc., then export that same name here. Nothing is hardcoded.
#   GROQ_API_KEY=
#   OPENROUTER_API_KEY=

# ── Power-user knobs (rarely needed) ─────────────────────────────
# The binary also honours these env vars when set; see
# kernel/config/config.go for exact semantics. Uncomment only if
# you know why you need to override the defaults.
#
#   OPENDRAY_CONFIG=/etc/opendray/config.toml   # custom config path
#   OPENDRAY_PLUGINS_DATA_DIR=/var/lib/opendray/plugins
#   OPENDRAY_ALLOW_LOCAL_PLUGINS=1              # allow local: install URIs
#   OPENDRAY_MARKETPLACE_URL=https://marketplace.opendray.dev
#   OPENDRAY_MARKETPLACE_MIRRORS=               # comma-separated fallbacks
#   OPENDRAY_MARKETPLACE_DIR=                   # on-disk catalog root
#   OPENDRAY_REVOCATION_POLL_HOURS=24
