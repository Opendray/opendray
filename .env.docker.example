# ── OpenDray Docker Compose environment ──────────────────────────────
#
# Copy to `.env` in the repo root before running `./scripts/opendray-docker up`.
# docker-compose.yml reads everything below; any value you leave blank
# falls back to OpenDray's in-code default.

# ── Image ────────────────────────────────────────────────────────
# Which image the compose stack pulls. Switch tags to upgrade/downgrade.
#   ghcr.io/opendray/opendray:latest-full  — tracks `main`
#   ghcr.io/opendray/opendray:vX.Y.Z-full  — pinned release
OPENDRAY_IMAGE=ghcr.io/opendray/opendray:latest-full

# ── Networking ───────────────────────────────────────────────────
# Host port that maps to the container's :8640. Change if 8640 is taken.
OPENDRAY_HTTP_PORT=8640

# ── Workspace ────────────────────────────────────────────────────
# Host path mounted into the container at /workspace — this is the
# directory the agent CLIs see as their project root. Use an absolute
# path if the compose file isn't run from this repo.
OPENDRAY_WORKSPACE=./workspace

# ── Postgres ─────────────────────────────────────────────────────
# These are used by BOTH the postgres container (to initialize the DB)
# and the opendray container (to connect). Changing them after first
# boot requires dropping the `pgdata` volume.
DB_USER=opendray
DB_PASSWORD=change-me-to-something-long-and-random
DB_NAME=opendray

# ── Auth ─────────────────────────────────────────────────────────
# Leave blank in local dev to disable JWT auth entirely. In anything
# public-facing set a random 32+ byte secret and an admin password.
JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Runtime tunables ─────────────────────────────────────────────
AUTO_RESUME=true
IDLE_THRESHOLD_SECONDS=8

# ── Agent API keys (all optional) ────────────────────────────────
# Leave any line blank to use that CLI's cached OAuth login instead
# (run `./scripts/opendray-docker login <agent>` once to seed it).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Telegram bridge (optional) ───────────────────────────────────
OPENDRAY_TELEGRAM_BOT_TOKEN=
