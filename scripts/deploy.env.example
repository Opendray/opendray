# Copy to scripts/deploy.env (gitignored) and fill in.
# Never commit this file with real values.
#
# deploy_release.sh reads this with `set -a; source`, so shell-quoting rules
# apply: pass passwords with quotes if they contain special chars.
#
# The script defaults to LOCAL mode (same box as the running opendray
# service). In that case you can leave EVERY OPENDRAY_* var empty unless
# your install deviates from the standard layout.

# ── Backend deploy target ────────────────────────────────────────────

# Leave empty / unset for LOCAL mode (same box). Set to an ssh target
# like "root@192.168.3.XX" only when deploying from a different machine.
# OPENDRAY_DEPLOY_HOST=""

# Where the running opendray binary lives on the target.
# OPENDRAY_DEPLOY_BIN_PATH="/opt/opendray/opendray"

# systemd unit name for the service.
# OPENDRAY_DEPLOY_SERVICE="opendray.service"

# Health-check URL. In local mode the default 127.0.0.1 is correct.
# OPENDRAY_HEALTH_URL="http://127.0.0.1:8640/api/health"

# Remote mode only — SSH key path.
# OPENDRAY_SSH_KEY="$HOME/.ssh/home_lab_key"

# ── UNAS SMB upload ──────────────────────────────────────────────────
UNAS_HOST="//192.168.9.8/Claude_Workspace"
UNAS_USER="your_unas_user"
UNAS_PASSWORD="your_unas_password"
UNAS_PATH="OpenDray/android"

# ── Optional tool overrides ──────────────────────────────────────────
# FLUTTER_HOME="$HOME/flutter"
# GO_BIN="/usr/local/go/bin/go"

# ── Phase skip flags (for partial runs) ──────────────────────────────
# SKIP_BACKEND=1    # don't rebuild/deploy Go binary
# SKIP_APK=1        # don't rebuild APK (useful if already built)
# SKIP_UNAS=1       # don't upload to UNAS
# NO_BUMP=1         # don't auto-increment pubspec.yaml build number
