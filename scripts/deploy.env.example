# scripts/deploy.env — local config for deploy_release.sh (syz LXC only).
#
# Copy to scripts/deploy.env (gitignored) and set UNAS_PASSWORD at minimum.
# Everything else has sensible defaults pinned to the home-lab setup.
#
# Password precedence:
#   1. $UNAS_PASSWORD env var (or this file's UNAS_PASSWORD line)
#   2. $HOME/.config/opendray/unas.pw (mode 600)
#   3. error + abort

# ── Required ──────────────────────────────────────────────────────────
# Either set it here OR put it in ~/.config/opendray/unas.pw
# UNAS_PASSWORD="your_unas_password"

# ── UNAS overrides (match upload-unas skill conventions) ──────────────
# UNAS_SERVER="192.168.9.8"
# UNAS_SHARE="Claude_Workspace"
# UNAS_USER="linivek"
# UNAS_PROJECT="OpenDray"          # directory under the share: <SHARE>/<PROJECT>/android/

# ── Backend overrides (standard syz LXC layout) ──────────────────────
# OPENDRAY_DEPLOY_BIN_PATH="/opt/opendray/opendray"
# OPENDRAY_DEPLOY_SERVICE="opendray.service"
# OPENDRAY_HEALTH_URL="http://127.0.0.1:8640/api/health"

# ── Tool overrides ────────────────────────────────────────────────────
# FLUTTER_HOME="$HOME/flutter"
# GO_BIN="/usr/local/go/bin/go"

# ── Flags ─────────────────────────────────────────────────────────────
# NO_BUMP=1   # don't auto-increment pubspec.yaml build number
