# Binary
bin/
*.exe

# Release tarballs / deploy artefacts
dist/

# Frontend
web/node_modules/
web/dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo

# Environment (never commit — DB passwords etc.)
.env
.env.*
!.env.example
!.env.docker.example

# Runtime logs (not the gateway/logs package or plugins/panels/log-viewer)
/logs/
app/logs/

# Plugin data
plugins/*/data/

# Deploy script config (hosts + SMB password)
scripts/deploy.env

# ── Public-repo slim-down ────────────────────────────────
# Local-only files kept out of the public mirror. Working tree stays
# intact; these just don't ship to GitHub.

CLAUDE.md
deploy/

# Docs — only the logo + Docker guide survive (README references them)
/docs/*
!/docs/logo.png
!/docs/logo.svg
!/docs/DOCKER.md
# Architecture decision records ship with code; Obsidian holds the rest.
!/docs/architecture/
!/docs/architecture/*.md

# Marketing / docs site — hosted separately
/website/

# Gitea-specific CI (self-hosted only)
/.gitea/

# Flutter mobile scaffolding — web build target still has everything it
# needs (app/lib, app/web, app/assets, app/pubspec.*, app/test). Mobile
# platforms don't ship publicly until they're actually supported.
app/android/
app/ios/
app/build_release.sh

# Internal deployment / release tooling (UNAS, LXC, sudoers bootstrap)
scripts/bootstrap_sudoers.sh
scripts/build_release.sh
scripts/deploy_release.sh
scripts/unas_upload.py
scripts/verify-deploy.sh
design/
.claude
.gitignore