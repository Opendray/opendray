# Copy to .env and edit values for your local opendray instance.
# .env is gitignored.

# opendray gateway base URL (no trailing slash).
OPENDRAY_BASE=http://127.0.0.1:8770

# Admin credentials — used ONLY when:
#   1. .demo-state.json doesn't exist yet (first run, fresh
#      registration), or
#   2. The saved api_key returns 401 because the operator rotated
#      it from the UI (recovery path).
#
# After successful registration the demo persists the api_key in
# .demo-state.json (mode 0600) and never asks for admin
# credentials again.
OPENDRAY_ADMIN_USER=admin
OPENDRAY_ADMIN_PASSWORD=12345678

# Name registered for this demo. The first run registers a new
# integration row under this name and saves its api_key locally.
INTEGRATION_NAME=demo-client

# How long to listen for events on the WebSocket before exiting.
EVENT_LISTEN_SECONDS=15

# Working directory for the demo session that gets spawned.
# Defaults to /tmp.
SESSION_CWD=/tmp
