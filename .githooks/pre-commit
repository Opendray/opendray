#!/usr/bin/env bash
# Pre-commit hook: catch README/translation drift before it lands.
#
# Fires when README.md is touched without README.zh-CN.md (or vice
# versa), so the English + Simplified-Chinese versions stay in lock-
# step. Bypass once with:  git commit --no-verify
#
# Activate once per clone:
#     git config core.hooksPath .githooks
#
# CI repeats the same check in .github/workflows/readme-sync.yml —
# this hook is the fast local tripwire, CI is the belt.

set -e

staged=$(git diff --cached --name-only)

en_touched=0
zh_touched=0
echo "$staged" | grep -qx "README.md"        && en_touched=1 || true
echo "$staged" | grep -qx "README.zh-CN.md"  && zh_touched=1 || true

if [ "$en_touched" = "1" ] && [ "$zh_touched" = "0" ]; then
    printf '\033[1;33m✗ README.md was modified, but README.zh-CN.md was not.\033[0m\n' >&2
    printf '  Update the Simplified-Chinese translation to match, or skip\n' >&2
    printf '  this check with: git commit --no-verify\n' >&2
    exit 1
fi

if [ "$zh_touched" = "1" ] && [ "$en_touched" = "0" ]; then
    printf '\033[1;33m✗ README.zh-CN.md was modified, but README.md was not.\033[0m\n' >&2
    printf '  Update the English source to match, or skip this check\n' >&2
    printf '  with: git commit --no-verify\n' >&2
    exit 1
fi

exit 0
