{
  "$schema": "https://opendray.dev/schemas/plugin-manifest-v1.json",
  "name": "claude",
  "displayName": "Claude Code",
  "description": "Anthropic Claude Code CLI — agentic coding with tool use, MCP, and session resume",
  "icon": "🟣",
  "version": "1.1.2",
  "publisher": "opendray-builtin",
  "engines": { "opendray": "^1.0.0" },
  "form": "declarative",
  "activation": ["onStartup"],
  "type": "cli",
  "cli": {
    "command": "claude",
    "defaultArgs": [],
    "detectCmd": "which claude"
  },
  "capabilities": {
    "models": [],
    "supportsResume": true,
    "supportsStream": true,
    "supportsImages": true,
    "supportsMcp": true,
    "dynamicModels": false
  },
  "configSchema": [
    {
      "key": "authType",
      "label": "Authentication",
      "type": "select",
      "group": "auth",
      "options": ["env", "custom"],
      "default": "env",
      "description": "env = read ANTHROPIC_API_KEY from system; falls back to the Claude CLI's own login when unset (use the Accounts section below to manage multiple tokens) · custom = use the key below"
    },
    {
      "key": "apiKey",
      "label": "API Key",
      "type": "secret",
      "group": "auth",
      "envVar": "ANTHROPIC_API_KEY",
      "placeholder": "sk-ant-...",
      "dependsOn": "authType",
      "dependsVal": "custom"
    },
    {
      "key": "bypassPermissions",
      "label": "Bypass Permissions",
      "type": "boolean",
      "group": "runtime",
      "default": false,
      "cliFlag": "--dangerously-skip-permissions",
      "description": "Skip all permission prompts — full autonomous mode"
    },
    {
      "key": "maxTurns",
      "label": "Max Turns",
      "type": "number",
      "group": "runtime",
      "description": "Limit autonomous agentic turns (0 = unlimited)"
    },
    {
      "key": "command",
      "label": "Command Path",
      "type": "string",
      "group": "advanced",
      "placeholder": "claude"
    },
    {
      "key": "extraArgs",
      "label": "Extra CLI Args",
      "type": "args",
      "group": "advanced"
    }
  ],
  "contributes": {
    "activityBar": [
      { "id": "claude", "icon": "🟣", "title": "Claude Code", "viewId": "claude" }
    ],
    "views": [
      { "id": "claude", "title": "Claude Code", "container": "activityBar", "render": "declarative" }
    ]
  },
  "required": true
}
