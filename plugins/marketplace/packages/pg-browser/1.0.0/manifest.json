{
  "$schema": "https://opendray.dev/schemas/plugin-manifest-v1.json",
  "name": "pg-browser",
  "version": "1.0.0",
  "publisher": "opendray-examples",
  "displayName": "PostgreSQL Browser",
  "displayName_zh": "PostgreSQL 浏览器",
  "description": "Browse PostgreSQL databases, schemas, tables, and run a sample SELECT. v1 rewrite of the legacy in-process database panel — now a sidecar that the host platform can install, permission-gate, and sandbox like any third-party plugin.",
  "description_zh": "浏览 PostgreSQL 的数据库、模式、表,并运行示例 SELECT。原先集成在进程内的数据库面板的 v1 重写 —— 现在以 sidecar 形式运行,可被宿主安装、权限控制并沙箱化,和其他第三方插件一视同仁。",
  "icon": "🐘",
  "engines": { "opendray": "^1.0.0" },
  "form": "host",
  "activation": ["onStartup"],
  "host": {
    "entry": "sidecar.js",
    "runtime": "node",
    "protocol": "jsonrpc-stdio",
    "restart": "on-failure",
    "idleShutdownMinutes": 10
  },
  "configSchema": [
    {
      "key": "host",
      "label": "Host",
      "label_zh": "主机",
      "type": "string",
      "required": true,
      "group": "connection",
      "placeholder": "db.example.com",
      "default": "127.0.0.1"
    },
    {
      "key": "port",
      "label": "Port",
      "label_zh": "端口",
      "type": "number",
      "required": true,
      "group": "connection",
      "default": 5432
    },
    {
      "key": "user",
      "label": "User",
      "label_zh": "用户",
      "type": "string",
      "required": true,
      "group": "connection",
      "placeholder": "readonly_user"
    },
    {
      "key": "password",
      "label": "Password",
      "label_zh": "密码",
      "type": "secret",
      "required": true,
      "group": "connection",
      "description": "Stored encrypted via the plugin secret cap (AES-GCM).",
      "description_zh": "通过插件 secret 能力加密存储(AES-GCM)。"
    },
    {
      "key": "database",
      "label": "Bootstrap database",
      "label_zh": "引导数据库",
      "type": "string",
      "required": true,
      "group": "connection",
      "default": "postgres",
      "description": "Default database to connect to. list-databases works regardless.",
      "description_zh": "默认连接的数据库。list-databases 命令不受此设置影响。"
    },
    {
      "key": "sslMode",
      "label": "SSL mode",
      "label_zh": "SSL 模式",
      "type": "select",
      "group": "connection",
      "options": ["disable", "require", "verify-full"],
      "default": "disable"
    }
  ],
  "contributes": {
    "commands": [
      {
        "id": "pg-browser.info",
        "title": "Postgres: Connection info",
        "icon": "🐘",
        "run": { "kind": "host", "method": "info" }
      },
      {
        "id": "pg-browser.list-databases",
        "title": "Postgres: List databases",
        "icon": "🐘",
        "run": { "kind": "host", "method": "listDatabases" }
      },
      {
        "id": "pg-browser.list-schemas",
        "title": "Postgres: List schemas",
        "icon": "🐘",
        "run": { "kind": "host", "method": "listSchemas" }
      },
      {
        "id": "pg-browser.list-tables",
        "title": "Postgres: List tables (public schema)",
        "icon": "🐘",
        "run": { "kind": "host", "method": "listTables" }
      },
      {
        "id": "pg-browser.sample-query",
        "title": "Postgres: Sample SELECT",
        "icon": "🐘",
        "run": { "kind": "host", "method": "sampleQuery" }
      }
    ]
  },
  "permissions": {
    "storage": true,
    "secret": true
  }
}
