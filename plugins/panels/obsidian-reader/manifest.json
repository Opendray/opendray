{
  "name": "obsidian-reader",
  "displayName": "Obsidian Reader",
  "description": "Browse and read Obsidian vault documents from a Git repository (Gitea, GitHub, etc.)",
  "icon": "📄",
  "version": "1.0.0",
  "type": "panel",
  "category": "docs",
  "capabilities": {
    "models": [],
    "supportsResume": false,
    "supportsStream": false,
    "supportsImages": false,
    "supportsMcp": false,
    "dynamicModels": false
  },
  "configSchema": [
    {
      "key": "forgeType",
      "label": "Git Forge",
      "type": "select",
      "group": "connection",
      "options": ["gitea", "github", "gitlab"],
      "default": "gitea",
      "description": "Type of Git hosting service"
    },
    {
      "key": "baseUrl",
      "label": "Server URL",
      "type": "string",
      "group": "connection",
      "placeholder": "https://gitea.example.com",
      "required": true,
      "description": "Git forge base URL (no trailing slash)"
    },
    {
      "key": "repo",
      "label": "Repository",
      "type": "string",
      "group": "connection",
      "placeholder": "your-user/your-vault",
      "required": true,
      "description": "owner/repo format"
    },
    {
      "key": "token",
      "label": "Access Token",
      "type": "secret",
      "group": "auth",
      "placeholder": "your-gitea-token",
      "description": "API token for private repositories. Leave empty for public repos."
    },
    {
      "key": "branch",
      "label": "Branch",
      "type": "string",
      "group": "connection",
      "default": "main",
      "description": "Branch to read from"
    },
    {
      "key": "basePath",
      "label": "Base Paths",
      "type": "string",
      "group": "connection",
      "placeholder": "Projects/,Infrastructure/",
      "description": "Directories to show (comma-separated for multiple, e.g. 'Projects/,Infrastructure/'). Leave empty to show entire repo."
    },
    {
      "key": "fileExtensions",
      "label": "File Extensions",
      "type": "string",
      "group": "advanced",
      "default": ".md",
      "description": "Comma-separated file extensions to show (e.g. .md,.txt)"
    }
  ]
}
