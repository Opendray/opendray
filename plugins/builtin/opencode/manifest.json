{
  "$schema": "https://opendray.dev/schemas/plugin-manifest-v1.json",
  "name": "opencode",
  "displayName": "OpenCode",
  "description": "OpenCode — provider-agnostic agentic coding CLI. Connects to any OpenAI-compatible endpoint through the LLM Providers panel, giving you Claude-Code-like tool use on Ollama, LM Studio, Groq, Gemini, etc.",
  "icon": "🤖",
  "version": "1.0.0",
  "publisher": "opendray-builtin",
  "engines": { "opendray": "^1.0.0" },
  "form": "declarative",
  "activation": ["onStartup"],
  "type": "cli",
  "cli": {
    "command": "opencode",
    "defaultArgs": [],
    "detectCmd": "which opencode"
  },
  "capabilities": {
    "models": [],
    "supportsResume": true,
    "supportsStream": true,
    "supportsImages": false,
    "supportsMcp": true,
    "dynamicModels": true
  },
  "configSchema": [
    {
      "key": "command",
      "label": "Command Path",
      "type": "string",
      "group": "advanced",
      "placeholder": "opencode",
      "description": "Path to the opencode binary on the NTC host."
    },
    {
      "key": "extraArgs",
      "label": "Extra CLI Args",
      "type": "args",
      "group": "advanced"
    }
  ]
}
