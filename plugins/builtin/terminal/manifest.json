{
  "$schema": "https://opendray.dev/schemas/plugin-manifest-v1.json",
  "name": "terminal",
  "displayName": "Terminal",
  "displayName_zh": "终端",
  "description": "System login shell — zsh, bash, or configured shell",
  "description_zh": "系统登录 shell —— zsh、bash 或已配置的 shell",
  "icon": "⬛",
  "version": "1.0.0",
  "publisher": "opendray-builtin",
  "engines": { "opendray": "^1.0.0" },
  "form": "declarative",
  "activation": ["onStartup"],
  "type": "shell",
  "cli": {
    "command": "auto",
    "defaultArgs": ["-l"],
    "detectCmd": "true"
  },
  "capabilities": {
    "models": [],
    "supportsResume": false,
    "supportsStream": true,
    "supportsImages": false,
    "supportsMcp": false,
    "dynamicModels": false
  },
  "configSchema": [
    {
      "key": "command",
      "label": "Shell",
      "label_zh": "Shell",
      "type": "select",
      "group": "runtime",
      "options": [
        "auto",
        "/bin/zsh",
        "/bin/bash",
        "/bin/sh",
        "/usr/bin/zsh",
        "/usr/bin/bash",
        "/usr/local/bin/zsh",
        "/usr/local/bin/bash",
        "/opt/homebrew/bin/zsh",
        "/opt/homebrew/bin/bash"
      ],
      "default": "auto",
      "description": "Login shell. 'auto' detects zsh → bash → sh from $SHELL or $PATH, falling back gracefully across macOS, Linux distros, and minimal containers.",
      "description_zh": "登录 shell。选 'auto' 会从 $SHELL 或 $PATH 依次尝试 zsh → bash → sh,兼容 macOS、各 Linux 发行版和精简容器镜像。"
    },
    {
      "key": "extraArgs",
      "label": "Shell Args",
      "label_zh": "Shell 参数",
      "type": "args",
      "group": "advanced",
      "default": "-l"
    }
  ],
  "contributes": {
    "activityBar": [
      { "id": "terminal", "icon": "⬛", "title": "Terminal", "viewId": "terminal" }
    ],
    "views": [
      { "id": "terminal", "title": "Terminal", "container": "activityBar", "render": "declarative" }
    ]
  },
  "required": true
}
